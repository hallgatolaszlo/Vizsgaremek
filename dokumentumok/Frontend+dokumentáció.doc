<p local-id=3D"95631276e073">Modal megjelen=C3=ADt=C3=A9s (h=C3=A1tt=C3=A9r=
 els=C3=B6t=C3=A9t=C3=ADt=C3=A9s)</p></li>
<li local-id=3D"75838c1ece1a">
<p local-id=3D"fa4a327eb3ba">Testreszabhat=C3=B3 c=C3=ADm, le=C3=ADr=C3=A1s=
 =C3=A9s tartalom</p></li>
<li local-id=3D"bb3aee138d6e">
<p local-id=3D"87a18f7d7fc8">Anim=C3=A1lt be/kimenet</p></li>
<li local-id=3D"127a684087df">
<p local-id=3D"8161e70f7d67">Maxim=C3=A1lis magass=C3=A1g korl=C3=A1toz=C3=
=A1s (90vh)</p></li>
<li local-id=3D"6bb619c477a1">
<p local-id=3D"56dbeefdbe2b">Glob=C3=A1lisan is haszn=C3=A1lhat=C3=B3 a use=
DialogStore-on kereszt=C3=BCl</p></li>
</ul>
<h2 local-id=3D"95f323dae699" id=3D"Frontenddokument=C3=A1ci=C3=B3-5.8.Val=
=C3=B3sidej=C5=B1=C3=A9rtes=C3=ADt=C3=A9sek(SignalR)">5.8. Val=C3=B3s idej=
=C5=B1 =C3=A9rtes=C3=ADt=C3=A9sek (SignalR)</h2>

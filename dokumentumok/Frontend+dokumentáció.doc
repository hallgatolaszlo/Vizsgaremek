=E2=94=82 Jellemz=C5=91 =E2=94=82 Web =E2=94=82 Mobil * =E2=94=82<br><br>
=E2=94=82 Keretrendszer =E2=94=82 Next.js =E2=94=82 Expo (React Native) =E2=
=94=82<br>
=E2=94=82 Navig=C3=A1ci=C3=B3 =E2=94=82 Next.js App Router =E2=94=82 Expo R=
outer (Tabs) =E2=94=82<br>
=E2=94=82 T=C3=A9ma kezel=C3=A9s =E2=94=82 NextThemeProvider =E2=94=82 Reac=
t Navigation Theme=E2=94=82<br>
=E2=94=82 Token t=C3=A1rol=C3=A1s =E2=94=82 HTTP cookie-k =E2=94=82 expo-se=
cure-store =E2=94=82<br>
=E2=94=82 Auth header =E2=94=82 Cookie (automatikus) =E2=94=82 Bearer token=
 (header) =E2=94=82<br>
=E2=94=82 Build rendszer =E2=94=82 Turbopack =E2=94=82 Metro bundler =E2=94=
=82<br>
=E2=94=82 Platform detekt=C3=A1l=C3=A1s =E2=94=82 isNative() =3D false =E2=
=94=82 isNative() =3D true =E2=94=82<br>
=E2=94=82 UI framework =E2=94=82 Tamagui (web) =E2=94=82 Tamagui (native) =
=E2=94=82<br>

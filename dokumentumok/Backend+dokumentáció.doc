g, =C3=A9s nem saj=C3=A1t<br>
 maga-e a c=C3=A9lszem=C3=A9ly. Sikeres ment=C3=A9s ut=C3=A1n SignalR-en<br=
>
 kereszt=C3=BCl val=C3=B3s idej=C5=B1 =C3=A9rtes=C3=ADt=C3=A9st k=C3=BCld a=
 c=C3=A9lfelhaszn=C3=A1l=C3=B3nak.</p>
